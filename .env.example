# Environment Configuration
# Copy this to .env.local and update with actual values

# Node Environment
NODE_ENV=production

# Application Settings
VITE_APP_NAME=CraftMySarees
VITE_APP_DESCRIPTION=Premium Indian Saree E-Commerce Store

# API Configuration (if needed)
# VITE_API_URL=https://api.craftmysarees.com
# VITE_API_KEY=your_api_key_here

# Analytics (optional)
# VITE_GOOGLE_ANALYTICS_ID=UA-XXXXX-XX

# Email Configuration (if using contact forms)
# VITE_CONTACT_EMAIL=contact@craftmysarees.com

# Payment Gateway (if needed)
# VITE_STRIPE_PUBLIC_KEY=pk_live_xxxxx

# Social Media
# VITE_FACEBOOK_URL=https://facebook.com/craftmysarees
# VITE_INSTAGRAM_URL=https://instagram.com/craftmysarees
# VITE_TWITTER_URL=https://twitter.com/craftmysarees

# Feature Flags
VITE_ENABLE_ANIMATIONS=true
VITE_ENABLE_INTRO=true
VITE_DEBUG_MODE=false
